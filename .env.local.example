# ==============================================================================
# Imago (Open Source) - Environment Configuration
# ==============================================================================

# ==============================================================================
# Functional Models Configuration (4 Models Support)
# ==============================================================================

# [1] Text to Image & [2] Image to Image
# Backend Provider Config (Expects z-image compatible API)
IMAGE_API_TOKEN=
IMAGE_API_URL=
IMAGE_CREATE_TASK_PATH=/api/v1/jobs/createTask
IMAGE_QUERY_TASK_PATH=/api/v1/jobs/recordInfo

# [3] Text to Video & [4] Image to Video
# Backend Provider Config (Expects Wan 2.6 compatible API)
VIDEO_API_TOKEN=
VIDEO_API_URL=
VIDEO_CREATE_TASK_PATH=/api/v1/jobs/createTask
VIDEO_QUERY_TASK_PATH=/api/v1/jobs/recordInfo

# Display Labels (Optional Override)
NEXT_PUBLIC_LABEL_TEXT_TO_IMAGE="Text to Image"
NEXT_PUBLIC_LABEL_IMAGE_TO_IMAGE="Image to Image"
NEXT_PUBLIC_LABEL_TEXT_TO_VIDEO="Text to Video"
NEXT_PUBLIC_LABEL_IMAGE_TO_VIDEO="Image to Video"

# Usage Limits & Costs
NEXT_PUBLIC_IMAGE_DAILY_LIMIT=10
NEXT_PUBLIC_IMAGE_CREDIT_COST=10
NEXT_PUBLIC_VIDEO_DAILY_LIMIT=2
NEXT_PUBLIC_VIDEO_CREDIT_COST=40

# ==============================================================================
# System Settings
# ==============================================================================
NEXT_PUBLIC_APP_NAME=Imago
NEXT_PUBLIC_APP_SHORT_NAME=Imago
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_TITLE="Imago · AI Image & Video Generator"
NEXT_PUBLIC_CONTACT_EMAIL=hello@example.com
NEXT_PUBLIC_STORAGE_PREFIX=imago
NEXT_PUBLIC_EVENT_PREFIX=imago
NEXT_PUBLIC_DOWNLOAD_PREFIX=imago
NEXT_PUBLIC_SITE_DESCRIPTION="Imago is a powerful AI creative studio for generating images and videos. Customize styles, poses, and scenes instantly."
NEXT_PUBLIC_SITE_KEYWORDS="AI generator, Text to Image, Text to Video, AI Art, Creative Tool, Imago"
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_OG_IMAGE_PATH=/og-image.png
# Age gate toggle: set to "false" to disable 18+ verification page
NEXT_PUBLIC_AGE_GATE_ENABLED=true
# Custom logo path (default: /favicon.svg)
NEXT_PUBLIC_LOGO_PATH=/favicon.svg
CDN_HOST=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Legacy (fallback for NEXT_PUBLIC_APP_URL)
# NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Stripe (Optional)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# R2 Storage (Optional)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ACCOUNT_ID=
R2_PUBLIC_URL=
